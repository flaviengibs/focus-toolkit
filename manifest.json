{
  "manifest_version": 3,
  "name": "Mode Sombre Auto",
  "version": "2.0",
  "description": "Mode sombre automatique avec contrôle manuel",

  "permissions": ["storage", "scripting", "tabs", "alarms"],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Mode sombre"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": { 
      "128" : "apple.png" 
  }
}
